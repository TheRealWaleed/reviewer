PORT=3000
HOST=0.0.0.0
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-5-20250929
TRIGGER_MODE=all
TRIGGER_LABEL=ai-review
TRIGGER_COMMENT=/review
LOG_LEVEL=info

# GitLab (optional — at least one platform must be configured)
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com
GITLAB_WEBHOOK_SECRET=

# GitHub (optional — at least one platform must be configured)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Usage tracking
USAGE_MONTHLY_TOKEN_LIMIT=0
USAGE_MONTHLY_DOLLAR_LIMIT=0
USAGE_INPUT_TOKEN_COST=0.003
USAGE_OUTPUT_TOKEN_COST=0.015
USAGE_ALERT_WEBHOOK_URL=
USAGE_DATA_DIR=data
HEALTH_CHECK_TIMEOUT_MS=5000
